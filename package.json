{
  "name": "Wwbu",
  "productName": "Wwbu",
  "description": "Wwbu - Làm cho vui thôi",
  "version": "1.1.4",
  "author": "Quang Trọng <quangtrong1506@gmail.com>",
  "license": "MIT",
  "main": "app/background.js",
  "homepage": "https://github.com/quangtrong1506/pubg-overlay",
  "repository": {
    "type": "git",
    "url": "https://github.com/quangtrong1506/pubg-overlay.git"
  },
  "keywords": [
    "electron",
    "typescript",
    "nextjs",
    "nextron",
    "tailwindcss",
    "shadcn",
    "app-router",
    "monorepo"
  ],
  "scripts": {
    "dev": "concurrently -n shared,electron -c green,blue \"npm run packages:dev\" \"npm run electron:dev\"",
    "packages:dev": "npm run dev -C packages/shared-type",
    "packages:build": "npm run build -C packages",
    "next:dev": "next dev renderer",
    "next:build": "next build renderer",
    "electron:dev": "nextron",
    "electron:build": "nextron build",
    "electron:build-all": "nextron build --all",
    "electron:build-win": "nextron build --win",
    "electron:build-linux": "nextron build --linux",
    "electron:build-mac": "nextron build --mac",
    "build": "npm run packages:build && npm run electron:build",
    "format": "next lint renderer --fix && prettier --write ."
  },
  "dependencies": {
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "next": "14.2.35"
  },
  "devDependencies": {
    "electron-serve": "^1.3.0",
    "electron-store": "^8.2.0",
    "next-themes": "^0.4.6",
    "sha3": "^2.1.4",
    "shared-types": "file:./packages/shared-type",
    "typescript": "^5.4.5",
    "@types/node": "^22.5.4",
    "@types/react": "^18.2.52",
    "@types/react-dom": "^18.3.7",
    "electron": "^33.2.0",
    "electron-builder": "^25.0.5",
    "electron-log": "^5.4.0",
    "electron-updater": "^6.6.2",
    "nextron": "^9.1.0",
    "concurrently": "^9.2.1",
    "serve": "^14.2.3",
    "dotenv": "^16.5.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "15.0.3",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-import": "^2.30.0",
    "eslint-plugin-prettier": "^5.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-tailwindcss": "^3.17.4",
    "prettier": "^3.3.3",
    "prettier-plugin-tailwindcss": "^0.6.6",
    "tailwindcss": "^3.4.12",
    "postcss": "^8.4.49",
    "autoprefixer": "^10.4.19",
    "semantic-release": "^22.0.0",
    "@semantic-release/git": "^10.0.0",
    "@semantic-release/changelog": "^6.0.0",
    "@semantic-release/github": "^9.0.0",
    "@semantic-release/exec": "^6.0.0"
  }
}
